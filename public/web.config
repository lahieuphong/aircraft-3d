<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <defaultDocument enabled="true">
      <files>
        <clear />
        <add value="index.html" />
      </files>
    </defaultDocument>
    <directoryBrowse enabled="false" />

    <staticContent>
      <clientCache cacheControlMode="DisableCache" setEtag="true" />
      <remove fileExtension=".glb" />
      <mimeMap fileExtension=".glb" mimeType="model/gltf-binary" />
      <remove fileExtension=".gltf" />
      <mimeMap fileExtension=".gltf" mimeType="model/gltf+json" />
      <remove fileExtension=".bin" />
      <mimeMap fileExtension=".bin" mimeType="application/gltf-buffer" />
      <remove fileExtension=".ktx2" />
      <mimeMap fileExtension=".ktx2" mimeType="image/ktx2" />
      <remove fileExtension=".ktx" />
      <mimeMap fileExtension=".ktx" mimeType="image/ktx" />
      <remove fileExtension=".wasm" />
      <mimeMap fileExtension=".wasm" mimeType="application/wasm" />
      <remove fileExtension=".webp" />
      <mimeMap fileExtension=".webp" mimeType="image/webp" />
      <remove fileExtension=".mjs" />
      <mimeMap fileExtension=".mjs" mimeType="text/javascript" />
    </staticContent>

    <urlCompression doStaticCompression="true" doDynamicCompression="false" />

    <rewrite>
      <rules>
        <clear />
        <rule name="Allow ACME challenge" stopProcessing="true">
          <match url="^\.well-known/acme-challenge/.*$" />
          <action type="None" />
        </rule>
        <rule name="Canonical HTTPS host" stopProcessing="true">
          <match url="(.*)" />
          <conditions logicalGrouping="MatchAny">
            <add input="{HTTPS}" pattern="^OFF$" ignoreCase="true" />
            <add input="{HTTP_HOST}" pattern="^aircraft-3d\.hongvan\.net$" ignoreCase="true" negate="true" />
          </conditions>
          <action
            type="Redirect"
            url="https://aircraft-3d.hongvan.net/{R:1}"
            appendQueryString="true"
            redirectType="Permanent"
          />
        </rule>
      </rules>
    </rewrite>

    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
        <add name="Permissions-Policy" value="camera=(), microphone=(), geolocation=(), payment=(), usb=(), fullscreen=(self)" />
        <add name="X-Frame-Options" value="SAMEORIGIN" />
        <add name="Strict-Transport-Security" value="max-age=31536000" />
        <add
          name="Content-Security-Policy"
          value="default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' blob:; worker-src 'self' blob:; child-src 'self' blob:; object-src 'none'; base-uri 'self'; frame-ancestors 'self'; form-action 'self'; manifest-src 'self'"
        />
      </customHeaders>
    </httpProtocol>

    <security>
      <requestFiltering removeServerHeader="true">
        <verbs>
          <add verb="TRACE" allowed="false" />
        </verbs>
        <hiddenSegments>
          <add segment=".git" />
          <add segment=".next" />
          <add segment="node_modules" />
        </hiddenSegments>
      </requestFiltering>
    </security>

    <httpErrors errorMode="Custom" existingResponse="Replace">
      <remove statusCode="404" subStatusCode="-1" />
      <error statusCode="404" path="/404.html" responseMode="ExecuteURL" />
    </httpErrors>
  </system.webServer>

  <location path="_next/static">
    <system.webServer>
      <staticContent>
        <clientCache
          cacheControlMode="UseMaxAge"
          cacheControlMaxAge="365.00:00:00"
          cacheControlCustom="public, immutable"
          setEtag="true"
        />
      </staticContent>
    </system.webServer>
  </location>

  <location path="models">
    <system.webServer>
      <staticContent>
        <clientCache
          cacheControlMode="UseMaxAge"
          cacheControlMaxAge="7.00:00:00"
          cacheControlCustom="public, stale-while-revalidate=86400"
          setEtag="true"
        />
      </staticContent>
    </system.webServer>
  </location>
</configuration>
